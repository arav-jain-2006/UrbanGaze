<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ToolbarTitleBold" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="InputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:background">@drawable/bg_btn_black</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

<!--    Test-->
    <style name="chip">
        <item name="android:padding">8dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">#EAEAEA</item>
    </style>

    <style name="chipSelected">
        <item name="android:padding">8dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">#1E7F75</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>