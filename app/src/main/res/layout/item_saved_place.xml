<?xml version="1.0" encoding="utf-8" ?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEF2F1">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:padding="10dp"
            android:src="@drawable/location_pin"
            app:tint="@color/primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/txtName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Place Name"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#0F1A18"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/imgIcon"
            app:layout_constraintTop_toTopOf="@id/imgIcon"
            app:layout_constraintEnd_toStartOf="@id/btnRemove"/>

        <TextView
            android:id="@+id/txtAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Full address"
            android:textSize="13sp"
            android:textColor="#7A8A87"
            android:layout_marginStart="12dp"
            android:layout_marginTop="3dp"
            app:layout_constraintStart_toEndOf="@id/imgIcon"
            app:layout_constraintTop_toBottomOf="@id/txtName"
            app:layout_constraintEnd_toStartOf="@id/btnRemove"/>

        <ImageView
            android:id="@+id/btnRemove"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="8dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/bg_icon_circle"
            app:tint="@color/primary"
            android:backgroundTint="#77FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenMaps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Open in Google Maps"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:backgroundTint="#0F000000"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_map"
            app:iconTint="@color/primary"
            app:iconGravity="textStart"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/txtAddress"
            app:layout_constraintStart_toStartOf="@id/imgIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>