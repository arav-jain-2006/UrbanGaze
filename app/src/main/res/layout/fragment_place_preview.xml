<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="20dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="22dp"
        app:cardElevation="18dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0.5dp"
        app:strokeColor="#14000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/placeName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Place Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"/>

                <ImageButton
                    android:id="@+id/closeBtn"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_close_circle"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="6dp"
                    app:tint="#66000000" />
            </LinearLayout>

            <TextView
                android:id="@+id/placeDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500 m away"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_distance_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/placeAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full address goes here"
                android:textSize="14sp"
                android:textColor="#66000000"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="10dp"
                android:background="#12000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openMapsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    app:icon="@drawable/ic_map"
                    app:iconTint="@color/primary"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    android:text="Open in Maps"
                    android:textColor="@color/primary"
                    app:cornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#33000000"
                    android:backgroundTint="@color/background"
                    android:layout_marginEnd="8dp"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>